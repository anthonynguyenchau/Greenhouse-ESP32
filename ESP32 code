#include <WiFi.h>
#include <PubSubClient.h>
#include <DHTesp.h>

#define pinDATA 32 // SDA, or almost any other I/O pin
#define SOL_H 33
#define PR 35

#define LED_B 21
#define PUMP 18
#define VENT 23
#define HUMIDIFIER 19

#define knownResistor 10000.0

DHTesp dht;

int ledState = LOW;
int pumpState = LOW;
int humidifierState = LOW;
int ventState = LOW;

int low_power_mode = 0;

const char* ssid = ***;  
const char* password = ***; 
const char* mqtt_server = "test.mosquitto.org";
WiFiClient espclient;

String temp_str, hum_str, shum_str, lm_str; 
char temp[50], hum[50], shum[50], lm[50];

PubSubClient client(espclient); // Initialize client properly

unsigned long lastSendTime = 0; 
unsigned long lastSleepTime = 0;
const unsigned long sendInterval = 5000; // Send sensor data every 5 seconds
const unsigned long powerofInterval = 2 * 60 * 1000; // 2 minutes

// MQTT callback to handle incoming messages
void callback(char* topic, byte* payload, unsigned int length) {
    String message = "";

    // Convert payload to string
    for (int i = 0; i < length; i++) {
        message += (char)payload[i];
    }

    Serial.print("Message arrived [");
    Serial.print(topic);
    Serial.print("]: ");
    Serial.println(message);

    // Try to convert message to integer
    int command = message.toInt();
    
    if (command == 0 && message != "0") { 
        Serial.println("Error: Not a valid number");
        return;
    }

    // Handle incoming MQTT messages AND send status immediately
    switch (command) {
        case 21:
            digitalWrite(LED_B, HIGH); 
            ledState = HIGH;   
            client.publish("statusg", "21"); // Send status NOW
            Serial.println("LED ON");
            break;
        case 20:
            digitalWrite(LED_B, LOW);
            ledState = LOW;   
            client.publish("statusg", "20"); // Send status NOW
            Serial.println("LED OFF");
            break;
        case 31:
            digitalWrite(PUMP, HIGH);
            pumpState = HIGH;
            client.publish("statusg", "31");
            Serial.println("PUMP ON");
            break;
        case 30:
            digitalWrite(PUMP, LOW);
            pumpState = LOW;
            client.publish("statusg", "30");
            Serial.println("PUMP OFF");
            break;
        case 41:
            digitalWrite(HUMIDIFIER, HIGH);
            humidifierState = HIGH;
            client.publish("statusg", "41");
            Serial.println("HUMIDIFIER ON");
            break;
        case 40:
            digitalWrite(HUMIDIFIER, LOW);
            humidifierState = LOW;
            client.publish("statusg", "40");
            Serial.println("HUMIDIFIER OFF");
            break;
        case 51:
            digitalWrite(VENT, HIGH);
            ventState = HIGH;
            client.publish("statusg", "51");
            Serial.println("VENT ON");
            break;
        case 50:
            digitalWrite(VENT, LOW);
            ventState = LOW;
            client.publish("statusg", "50");
            Serial.println("VENT OFF");
            break;
        case 1:
            low_power_mode = 1;
            Serial.println("Low power mode ON");
            break;
        case 0:
            low_power_mode = 0;
            Serial.println("Low power mode OFF");
            break;
        default:
            Serial.println("Error: Unrecognized command");
            break;
    }
}

void reconnect() {
    // Loop until we're reconnected
    while (!client.connected()) {
        Serial.print("Attempting MQTT connection...");
        // Attempt to connect
        if (client.connect("ESP32test1")) {
            Serial.println("Connected to MQTT broker.");
            client.subscribe("commandgh");
            client.publish("ESPstatus", "on"); 
        } else {
            Serial.print("Failed to connect, rc=");
            Serial.print(client.state());
            Serial.println(" try again in 2 seconds");
            delay(2000); // Wait 2 seconds before retrying
        }
    }
}

void setup() {
    pinMode(LED_B, OUTPUT);
    pinMode(PUMP, OUTPUT);
    pinMode(HUMIDIFIER, OUTPUT);  
    pinMode(VENT, OUTPUT);

    Serial.begin(115200);

    // Setup DHT sensor 
    dht.setup(pinDATA, DHTesp::DHT22); 

    // Connect to Wi-Fi
    Serial.print("Connecting to ");
    Serial.println(ssid);
    WiFi.begin(ssid, password);
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
    }
    Serial.println("");
    Serial.println("Connected to Wi-Fi.");

    client.setServer(mqtt_server, 1883);
    client.setCallback(callback);
}

void loop() {
    if (!client.connected()) {
        reconnect();
    }
    client.loop(); // Crucial for receiving MQTT messages instantly

    // Timer for sending Sensor Data (Non-blocking)
    if (millis() - lastSendTime >= sendInterval) {
        lastSendTime = millis(); 

        // Get sensor readings
        float t = dht.getTemperature();
        float h = dht.getHumidity();
        
        // Soil Humidity Map (0-4095 -> 100-0%)
        float sh = map(analogRead(SOL_H), 0, 4095, 100, 0); 
        
        // Light Sensor Map (0-4095 -> 100-0%) -- LOGIC FIXED HERE
        // Assumes LDR circuit where 0 is dark and 4095 is bright light (or vice versa depending on wiring)
         int luxRaw = analogRead(PR);
        float lux = map(luxRaw, 0, 4095, 4095, 0);

        Serial.print("Soil Humidity: "); Serial.println(sh);
        Serial.print("Humidity: "); Serial.println(h);
        Serial.print("Temperature: "); Serial.println(t);
        Serial.print("Light Level: "); Serial.println(lux);
        
        if (dht.getStatus() != DHTesp::ERROR_NONE) {
            Serial.print("DHT Sensor Error: ");
            Serial.println(dht.getStatusString());
        }
        
        // Prepare data for MQTT
        temp_str = String(t);
        temp_str.toCharArray(temp, temp_str.length() + 1);

        hum_str = String(h);
        hum_str.toCharArray(hum, hum_str.length() + 1);

        shum_str = String(sh);
        shum_str.toCharArray(shum, shum_str.length() + 1);

        lm_str = String(lux);
        lm_str.toCharArray(lm, lm_str.length() + 1);

        // Publish sensor data
        if (client.connected()) {
            client.publish("tempg", temp);
            client.publish("humg", hum);
            client.publish("shumg", shum);
            client.publish("luxg", lm);
            client.publish("ESPstatus", "on");

            // Sleep mode handling
            if (low_power_mode == 1 && millis() - lastSleepTime >= powerofInterval) {
                lastSleepTime = millis();
                Serial.println("Going to deep sleep for 5 minutes");
                client.publish("ESPstatus", "off");
                esp_sleep_enable_timer_wakeup(5 * 60 * 1000000); // 5 minutes
                esp_deep_sleep_start();
            }
        }
    }
}
